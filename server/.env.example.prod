# App
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB_NAME"

# Redis
REDIS_URL="redis://default:PASSWORD@HOST:6379/0"

# JWT
JWT_SECRET="generate-a-secure-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# CORS
CORS_ORIGIN="https://glow.ge"

# Cookies (required in production for cross-domain auth)
COOKIE_DOMAIN=".glow.ge"
COOKIE_SECURE=true

# App URL (used for referral links and email links)
APP_URL="https://glow.ge"

# Email (Resend)
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="noreply@glow.ge"

# AI Image Generation — switch provider: "gemini" or "openai"
AI_PROVIDER="openai"

# Gemini config (used when AI_PROVIDER=gemini)
GEMINI_API_KEY="your-gemini-key-here"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GEMINI_TEXT_MODEL="gemini-2.5-pro"

# OpenAI config (used when AI_PROVIDER=openai)
OPENAI_API_KEY="sk-your-openai-key-here"
OPENAI_IMAGE_MODEL="gpt-image-1.5"
OPENAI_IMAGE_COUNT=1
OPENAI_IMAGE_PRESET="high"

# Launch Mode
LAUNCH_MODE=true
LAUNCH_DAILY_LIMIT=5

# Watermark & Download Quality
WATERMARK_ENABLED=false
IMAGE_DOWNLOAD_QUALITY=100
IMAGE_DOWNLOAD_FORMAT=png

# OTP (phone verification)
OTP_API_KEY="your_otp_api_key"
# SMS sender ID shown as the "from" on outgoing SMS (must be registered with gosms.ge)
SMS_SENDER_ID=GLOW

# Flitt payment gateway (booking prepayment / full payment, https://docs.flitt.com)
# Empty merchant id (0) = gateway off; booking prepay falls back to off-platform.
FLITT_MERCHANT_ID=0
FLITT_SECRET_KEY=
FLITT_API_URL="https://pay.flitt.com/api/checkout/url/"
BOOKING_ONLINE_PAYMENTS_ENABLED=false

# Merchant-review account provisioner (inject securely; never commit real values)
# REVIEWER_EMAIL=
# REVIEWER_PHONE=
# REVIEWER_PASSWORD=
# REVIEWER_USERNAME=glow-review-master
# Minutes a booking may hold a PENDING Flitt (online) payment before the stale-payment sweep
# fails the payment + cancels the booking to release the slot (~ Flitt order lifetime).
BOOKING_PAYMENT_TIMEOUT_MIN=45
# Minutes a booking may hold a PENDING offline (master-managed prepay) payment before the
# sweep ages it out. Much longer (1440 = 24h) so a booking merely awaiting the master's
# manual confirmation is never auto-cancelled at the short Flitt window.
OFFLINE_PAYMENT_TIMEOUT_MIN=1440
# Public URL of THIS API for the Flitt server callback (prod host).
PUBLIC_SERVER_URL="https://api.glow.ge"
